<%- include('../partials/header') %>

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">
        <% if (success) { %><div class="alert alert-success alert-dismissible fade show" role="alert"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
        <% if (error) { %><div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
        <div class="card border-0 shadow-sm category-table-card">
            <div class="card-header bg-transparent d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <h5 class="mb-1">View Category</h5>
                    <p class="text-body-secondary mb-0">Manage your category item list in table format.</p>
                </div>
                <a href="/add-category" class="btn btn-primary">
                    <i class="icon-base ri ri-add-line me-1"></i> Add Category
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive text-nowrap">
                    <table class="table table-hover align-middle mb-0 category-table">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Category Item Name</th>
                                <th>Created</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (categories && categories.length) { %>
                                <% categories.forEach((category, index) => { %>
                                    <tr>
                                        <td><span class="fw-semibold"><%= index + 1 %></span></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="category-avatar">
                                                    <i class="icon-base ri ri-price-tag-3-line"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0"><%= category.categoryName %></h6>
                                                    <small class="text-body-secondary">Category item</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><%= category.createdAt ? category.createdAt.toLocaleDateString('en-IN') : '-' %></td>
                                        <td class="text-end">
                                            <a href="/edit-category/<%= category._id %>" class="btn btn-icon btn-outline-warning btn-sm me-1" title="Edit">
                                                <i class="icon-base ri ri-edit-2-fill"></i>
                                            </a>
                                            <a href="/delete-category/<%= category._id %>" onclick="return confirm('Are you sure you want to delete this category?')" class="btn btn-icon btn-outline-danger btn-sm" title="Delete">
                                                <i class="icon-base ri ri-delete-bin-6-fill"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <div class="empty-category mx-auto">
                                            <i class="icon-base ri ri-folder-add-line"></i>
                                        </div>
                                        <h6 class="mt-3 mb-1">No category found</h6>
                                        <p class="text-body-secondary mb-3">Add your first category item from the add category page.</p>
                                        <a href="/add-category" class="btn btn-primary">Add Category</a>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <style>
        .category-table-card {
            border-radius: 18px;
            overflow: hidden;
        }
        .category-table thead th {
            font-size: 12px;
            letter-spacing: .04em;
        }
        .category-avatar,
        .empty-category {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(102, 108, 255, .12);
            color: var(--bs-primary);
        }
        .empty-category {
            width: 68px;
            height: 68px;
            font-size: 28px;
        }
    </style>

    <%- include('../partials/footer') %>
