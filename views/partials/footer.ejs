<!-- Place this tag before closing body tag for github widget button. -->
<script async="async" defer="defer" src="https://buttons.github.io/buttons.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const htmlEl = document.documentElement;
    const toggles = document.querySelectorAll('.layout-menu-toggle:not(.layout-overlay)');
    const overlay = document.querySelector('.layout-overlay');

    function closeSidebar() {
      htmlEl.classList.add('layout-menu-hidden');
      htmlEl.classList.remove('layout-menu-expanded');
      document.body.classList.remove('layout-menu-expanded');
    }

    function openSidebar() {
      htmlEl.classList.remove('layout-menu-hidden');
      htmlEl.classList.add('layout-menu-expanded');
      document.body.classList.add('layout-menu-expanded');
    }

    toggles.forEach(function (toggle) {
      toggle.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        if (htmlEl.classList.contains('layout-menu-hidden')) {
          openSidebar();
        } else {
          closeSidebar();
        }
      });
    });

    if (overlay) {
      overlay.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
      });
    }
  });
</script>
