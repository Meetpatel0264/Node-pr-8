<%
    const activePath = typeof currentPath !== "undefined" ? currentPath : "";
    const isDashboardActive = activePath === "/dashboard" || activePath === "/analytics";
    const isCategoryActive = activePath === "/add-category" || activePath === "/view-category" || activePath.startsWith("/edit-category");
    const isAddCategoryActive = activePath === "/add-category";
    const isViewCategoryActive = activePath === "/view-category" || activePath.startsWith("/edit-category");
    const isProductActive = activePath === "/add-product" || activePath === "/view-product" || activePath.startsWith("/edit-product");
    const isAddProductActive = activePath === "/add-product";
    const isViewProductActive = activePath === "/view-product" || activePath.startsWith("/edit-product");
%>

<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
    <div class="app-brand demo">
        <a href="/dashboard" class="app-brand-link">
            <img src="/images/favcon-icon/favicon.ico" alt="">
            <span class="app-brand-text demo menu-text fw-semibold ms-2">Admin Panel</span>
        </a>
        <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
            <i class="icon-base ri ri-menu-line icon-20px"></i>
        </a>
    </div>

    <div class="menu-inner-shadow"></div>

    <ul class="menu-inner py-1">
        <li class="menu-header mt-5"><span class="menu-header-text">Main</span></li>
        <li class="menu-item <%= isDashboardActive ? 'active' : '' %>">
            <a href="/dashboard" class="menu-link">
                <i class="menu-icon icon-base ri <%= isDashboardActive ? 'ri-home-smile-fill' : 'ri-home-smile-line' %>"></i>
                <div>Dashboard</div>
            </a>
        </li>
        <li class="menu-item <%= isCategoryActive ? 'active open' : '' %>">
            <a href="javascript:void(0);" class="menu-link menu-toggle">
                <i class="menu-icon icon-base ri <%= isCategoryActive ? 'ri-folder-3-fill' : 'ri-folder-3-line' %>"></i>
                <div>Category</div>
            </a>
            <ul class="menu-sub">
                <li class="menu-item <%= isAddCategoryActive ? 'active' : '' %>">
                    <a href="/add-category" class="menu-link">
                        <i class="menu-icon icon-base ri <%= isAddCategoryActive ? 'ri-add-box-fill' : 'ri-add-box-line' %>"></i>
                        <div>Add Category</div>
                    </a>
                </li>
                <li class="menu-item <%= isViewCategoryActive ? 'active' : '' %>">
                    <a href="/view-category" class="menu-link">
                        <i class="menu-icon icon-base ri <%= isViewCategoryActive ? 'ri-table-fill' : 'ri-table-line' %>"></i>
                        <div>View Category</div>
                    </a>
                </li>
            </ul>
        </li>
        <li class="menu-item <%= isProductActive ? 'active open' : '' %>">
            <a href="javascript:void(0);" class="menu-link menu-toggle">
                <i class="menu-icon icon-base ri <%= isProductActive ? 'ri-shopping-bag-3-fill' : 'ri-shopping-bag-3-line' %>"></i>
                <div>Product</div>
            </a>
            <ul class="menu-sub">
                <li class="menu-item <%= isAddProductActive ? 'active' : '' %>">
                    <a href="/add-product" class="menu-link">
                        <i class="menu-icon icon-base ri <%= isAddProductActive ? 'ri-add-box-fill' : 'ri-add-box-line' %>"></i>
                        <div>Add Product</div>
                    </a>
                </li>
                <li class="menu-item <%= isViewProductActive ? 'active' : '' %>">
                    <a href="/view-product" class="menu-link">
                        <i class="menu-icon icon-base ri <%= isViewProductActive ? 'ri-table-fill' : 'ri-table-line' %>"></i>
                        <div>View Product</div>
                    </a>
                </li>
            </ul>
        </li>
    </ul>
</aside>

<style>
    .profile-sidebar-link {
        color: inherit;
        background: rgba(46, 38, 61, 0.04);
        border: 1px solid rgba(46, 38, 61, 0.08);
        transition: 0.2s ease;
    }

    .profile-sidebar-link:hover {
        color: var(--bs-primary);
        background: rgba(102, 108, 255, 0.1);
    }

    .profile-sidebar-img {
        width: 42px;
        height: 42px;
        object-fit: cover;
        flex: 0 0 42px;
    }

    .sidebar-user-fixed {
        position: sticky;
        bottom: 1rem;
        margin: 1rem;
        padding: 12px;
        border-radius: 12px;
        background: var(--bs-paper-bg);
        border: 1px solid rgba(46, 38, 61, 0.08);
        box-shadow: 0 6px 18px rgba(46, 38, 61, 0.06);
        z-index: 2;
    }

    .sidebar-user-card {
        display: flex;
        align-items: center;
        gap: 10px;
        color: inherit;
    }

    .sidebar-user-card:hover h6 {
        color: var(--bs-primary);
    }

    .sidebar-user-img {
        width: 42px;
        height: 42px;
        object-fit: cover;
        flex: 0 0 42px;
    }

    .sidebar-user-info {
        min-width: 0;
    }
</style>
