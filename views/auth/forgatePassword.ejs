<!doctype html>
<html lang="en" class="layout-wide customizer-hide" data-assets-path="../assets/" data-template="vertical-menu-template-free">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Forgot Password | Materio</title>

  <link rel="icon" type="image/x-icon" href="/images/favcon-icon/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&ampdisplay=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/font/iconify-icons.css" />
  <link rel="stylesheet" href="/css/formsCss/node-waves.css" />
  <link rel="stylesheet" href="/css/authCss/core.css" />
  <link rel="stylesheet" href="/css/authCss/demo.css" />
  <link rel="stylesheet" href="/css/formsCss/perfect-scrollbar.css" />
  <link rel="stylesheet" href="/css/authCss/page-auth.css" />

  <script src="/js/helpers.js"></script>
  <script src="/js/config.js"></script>
</head>
<body>
  <div class="position-relative">
    <div class="authentication-wrapper authentication-basic container-p-y">
      <div class="authentication-inner py-6 mx-4">
        <div class="card p-sm-7 p-2">
          <div class="app-brand justify-content-center mt-5">
            <a href="/login" class="app-brand-link gap-3">
              <span class="app-brand-logo demo">
                <span class="text-primary">
                  <svg width="30" height="24" viewBox="0 0 250 196" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12.3002 1.25469L56.655 28.6432C59.0349 30.1128 60.4839 32.711 60.4839 35.5089V160.63C60.4839 163.468 58.9941 166.097 56.5603 167.553L12.2055 194.107C8.3836 196.395 3.43136 195.15 1.14435 191.327C0.395485 190.075 0 188.643 0 187.184V8.12039C0 3.66447 3.61061 0.0522461 8.06452 0.0522461C9.56056 0.0522461 11.0271 0.468577 12.3002 1.25469Z" fill="currentColor" />
                    <path opacity="0.077704" fill-rule="evenodd" clip-rule="evenodd" d="M0 65.2656L60.4839 99.9629V133.979L0 65.2656Z" fill="black" />
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12.2787 1.18923L125 70.3075V136.87L0 65.2465V8.06814C0 3.61223 3.61061 0 8.06452 0C9.552 0 11.0105 0.411583 12.2787 1.18923Z" fill="currentColor" />
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M237.721 1.18923L125 70.3075V136.87L250 65.2465V8.06814C250 3.61223 246.389 0 241.935 0C240.448 0 238.99 0.411583 237.721 1.18923Z" fill="currentColor" />
                  </svg>
                </span>
              </span>
              <span class="app-brand-text demo text-heading fw-semibold">Materio</span>
            </a>
          </div>

          <div class="card-body mt-1">
            <h4 class="mb-1">Forgot Password? 🔒</h4>
            <p class="mb-5">
              <% if (step === 'reset') { %>
                OTP verified. Enter and confirm your new password.
              <% } else if (step === 'otp') { %>
                A 6-digit OTP was sent to your registered email address.
              <% } else { %>
                Enter your registered Gmail address to generate an OTP.
              <% } %>
            </p>

            <% if (error) { %>
              <div class="alert alert-danger alert-dismissible auth-message-block" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <% if (success) { %>
              <div class="alert alert-success alert-dismissible auth-message-block" role="alert">
                <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <% if (step === 'reset') { %>
              <form class="mb-5" action="/forgot-password/reset" method="POST">
                <input type="hidden" name="email" value="<%= email %>" />
                <input type="hidden" name="token" value="<%= token %>" />

                <div class="form-floating form-floating-outline mb-5">
                  <input type="email" class="form-control" value="<%= email %>" readonly />
                  <label>Verified Email</label>
                </div>

                <div class="mb-5 form-password-toggle form-control-validation">
                  <div class="input-group input-group-merge">
                    <div class="form-floating form-floating-outline">
                      <input type="password" id="newPassword" class="form-control" name="newPassword" placeholder="Enter new password" required autofocus />
                      <label for="newPassword">New Password</label>
                    </div>
                    <span class="input-group-text cursor-pointer" data-password-toggle="true"><i class="icon-base ri ri-eye-off-line"></i></span>
                  </div>
                  <small class="text-muted d-block mt-2">Minimum 8 characters with uppercase, lowercase, number and special character.</small>
                </div>

                <div class="mb-5 form-password-toggle form-control-validation">
                  <div class="input-group input-group-merge">
                    <div class="form-floating form-floating-outline">
                      <input type="password" id="confirmPassword" class="form-control" name="confirmPassword" placeholder="Confirm new password" required />
                      <label for="confirmPassword">Confirm Password</label>
                    </div>
                    <span class="input-group-text cursor-pointer" data-password-toggle="true"><i class="icon-base ri ri-eye-off-line"></i></span>
                  </div>
                </div>

                <button type="submit" class="btn btn-primary d-grid w-100 mb-5">Update Password</button>
              </form>
            <% } else { %>
              <form class="mb-5" action="/forgatePassword" method="POST">
                <div class="form-floating form-floating-outline mb-5 form-control-validation">
                  <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" value="<%= email || '' %>" pattern="^[A-Za-z0-9._%+-]+@gmail\.com$" title="Please enter registered Gmail address only" required autofocus />
                  <label for="email">Email</label>
                </div>
                <button type="submit" class="btn btn-primary d-grid w-100 mb-5">Generate OTP</button>
              </form>
            <% } %>

            <div class="text-center">
              <a href="/login" class="d-flex align-items-center justify-content-center">
                <i class="icon-base ri ri-arrow-left-s-line scaleX-n1-rtl icon-20px me-1_5"></i>
                Back to login
              </a>
            </div>
          </div>
        </div>

        <img src="/images/dashboard/tree-3.png" alt="auth-tree" class="authentication-image-object-left d-none d-lg-block" />
        <img src="/images/dashboard/auth-basic-mask-light.png" class="authentication-image d-none d-lg-block scaleX-n1-rtl" height="172" alt="triangle-bg" />
        <img src="/images/dashboard/tree.png" alt="auth-tree" class="authentication-image-object-right d-none d-lg-block" />
      </div>
    </div>
  </div>

  <div class="modal fade" id="otpModal" tabindex="-1" aria-labelledby="otpModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <div>
            <h5 class="modal-title" id="otpModalLabel">Verify OTP</h5>
            <small class="text-muted">OTP expires in 10 minutes.</small>
          </div>
          <a href="/forgatePassword" class="btn-close" aria-label="Close"></a>
        </div>
        <div class="modal-body">
          <p class="mb-4">Enter the 6-digit OTP sent to your registered email address.</p>

          <form action="/forgot-password/verify-otp" method="POST">
            <input type="hidden" name="email" value="<%= email %>" />
            <input type="hidden" name="token" value="<%= token %>" />

            <div class="form-floating form-floating-outline mb-4">
              <input type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" minlength="6" class="form-control text-center fs-4" id="otp" name="otp" placeholder="Enter 6-digit OTP" autocomplete="one-time-code" required />
              <label for="otp">6-digit OTP</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">Verify OTP</button>
          </form>

          <form action="/forgot-password/resend-otp" method="POST">
            <input type="hidden" name="email" value="<%= email %>" />
            <input type="hidden" name="token" value="<%= token %>" />
            <button type="submit" id="resendOtpButton" class="btn btn-outline-secondary w-100" <%= resendSeconds > 0 ? 'disabled' : '' %>>
              <span id="resendButtonText"><%= resendSeconds > 0 ? `Resend OTP in ${resendSeconds}s` : 'Resend OTP' %></span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/jquery.js"></script>
  <script src="/js/popper.js"></script>
  <script src="/js/bootstrap.js"></script>
  <script src="/js/node-waves.js"></script>
  <script src="/js/perfect-scrollbar.js"></script>
  <script src="/js/menu.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/custom-validation.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const shouldOpenOtpModal = <%- JSON.stringify(openOtpModal) %>;
      const otpModalElement = document.getElementById("otpModal");

      if (shouldOpenOtpModal && otpModalElement) {
        const otpModal = new bootstrap.Modal(otpModalElement);
        otpModal.show();
      }

      let remainingSeconds = Number(<%- JSON.stringify(resendSeconds) %>) || 0;
      const resendButton = document.getElementById("resendOtpButton");
      const resendButtonText = document.getElementById("resendButtonText");

      if (resendButton && resendButtonText && remainingSeconds > 0) {
        const timer = setInterval(function () {
          remainingSeconds -= 1;

          if (remainingSeconds <= 0) {
            clearInterval(timer);
            resendButton.disabled = false;
            resendButtonText.textContent = "Resend OTP";
            return;
          }

          resendButtonText.textContent = `Resend OTP in ${remainingSeconds}s`;
        }, 1000);
      }
    });
  </script>
</body>
</html>
