<%- include('../partials/header') %>

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">
        <div class="row justify-content-center">
            <div class="col-xl-9 col-lg-10">
                <div class="card border-0 shadow-sm product-card">
                    <div class="card-header bg-transparent d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div>
                            <h5 class="mb-1">Edit Product</h5>
                            <p class="text-body-secondary mb-0">Update product details, category and image.</p>
                        </div>
                        <a href="/view-product" class="btn btn-sm btn-outline-primary"><i class="icon-base ri ri-arrow-left-line me-1"></i> Back</a>
                    </div>
                    <div class="card-body">
                        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
                        <form action="/update-product/<%= product._id %>" method="POST" enctype="multipart/form-data" class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label" for="productName">Product Name</label>
                                <input type="text" class="form-control form-control-lg" id="productName" name="productName" value="<%= product.productName %>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="categoryId">Product Category</label>
                                <select class="form-select form-select-lg" id="categoryId" name="categoryId" required>
                                    <option value="">Select category</option>
                                    <% categories.forEach(category => { %>
                                        <option value="<%= category._id %>" <%= String(product.categoryId) === String(category._id) ? 'selected' : '' %>><%= category.categoryName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="price">Price</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text">₹</span>
                                    <input type="number" class="form-control" id="price" name="price" min="0" step="0.01" value="<%= product.price %>" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="quantity">Quantity</label>
                                <input type="number" class="form-control form-control-lg" id="quantity" name="quantity" min="0" step="1" value="<%= product.quantity %>" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="description">Description</label>
                                <textarea class="form-control" id="description" name="description" rows="4"><%= product.description || '' %></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label d-block">Current Image</label>
                                <img src="<%= product.productImage %>" alt="<%= product.productName %>" class="current-product-image">
                            </div>
                            <div class="col-md-8">
                                <label class="form-label" for="productImage">Change Product Image</label>
                                <input type="file" class="form-control form-control-lg" id="productImage" name="productImage" accept="image/jpeg,image/png,image/webp">
                                <small class="text-body-secondary">Leave empty to keep the current image.</small>
                            </div>
                            <div class="col-12 d-flex gap-2 flex-wrap">
                                <button type="submit" class="btn btn-primary px-4"><i class="icon-base ri ri-save-3-line me-1"></i> Update Product</button>
                                <a href="/view-product" class="btn btn-outline-secondary px-4">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .product-card { border-radius: 18px; }
        .product-card .form-control, .product-card .form-select { border-radius: 12px; }
        .current-product-image { width: 130px; height: 110px; object-fit: cover; border-radius: 14px; border: 1px solid rgba(46,38,61,.12); }
    </style>

    <%- include('../partials/footer') %>
