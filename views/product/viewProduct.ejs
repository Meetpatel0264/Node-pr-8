<%- include('../partials/header') %>

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">
        <% if (success) { %><div class="alert alert-success alert-dismissible fade show" role="alert"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
        <% if (error) { %><div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

        <div class="card border-0 shadow-sm product-table-card">
            <div class="card-header bg-transparent d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <h5 class="mb-1">View Products</h5>
                    <p class="text-body-secondary mb-0">Manage products and their connected categories.</p>
                </div>
                <a href="/add-product" class="btn btn-primary"><i class="icon-base ri ri-add-line me-1"></i> Add Product</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive text-nowrap">
                    <table class="table table-hover align-middle mb-0 product-table">
                        <thead><tr><th>No.</th><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th class="text-end">Action</th></tr></thead>
                        <tbody>
                            <% if (products && products.length) { %>
                                <% products.forEach((product, index) => { %>
                                    <tr>
                                        <td><span class="fw-semibold"><%= index + 1 %></span></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="<%= product.productImage %>" alt="<%= product.productName %>" class="product-thumb">
                                                <div class="product-copy">
                                                    <h6 class="mb-0"><%= product.productName %></h6>
                                                    <small class="text-body-secondary"><%= product.description ? product.description.slice(0, 45) : 'No description' %><%= product.description && product.description.length > 45 ? '...' : '' %></small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-label-primary"><%= product.categoryId ? product.categoryId.categoryName : 'Category removed' %></span></td>
                                        <td class="fw-semibold">₹<%= Number(product.price).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        <td><span class="badge <%= product.quantity > 0 ? 'bg-label-success' : 'bg-label-danger' %>"><%= product.quantity %></span></td>
                                        <td class="text-end">
                                            <a href="/edit-product/<%= product._id %>" class="btn btn-icon btn-outline-warning btn-sm me-1" title="Edit"><i class="icon-base ri ri-edit-2-fill"></i></a>
                                            <a href="/delete-product/<%= product._id %>" onclick="return confirm('Are you sure you want to delete this product?')" class="btn btn-icon btn-outline-danger btn-sm" title="Delete"><i class="icon-base ri ri-delete-bin-6-fill"></i></a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="6" class="text-center py-5"><div class="empty-product mx-auto"><i class="icon-base ri ri-shopping-bag-3-line"></i></div><h6 class="mt-3 mb-1">No products found</h6><p class="text-body-secondary mb-3">Add your first product and select its category.</p><a href="/add-product" class="btn btn-primary">Add Product</a></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <style>
        .product-table-card { border-radius: 18px; overflow: hidden; }
        .product-thumb { width: 58px; height: 58px; border-radius: 13px; object-fit: cover; border: 1px solid rgba(46,38,61,.1); }
        .product-copy { min-width: 190px; max-width: 300px; white-space: normal; }
        .empty-product { width: 68px; height: 68px; border-radius: 18px; display:flex; align-items:center; justify-content:center; background:rgba(102,108,255,.12); color:var(--bs-primary); font-size:28px; }
    </style>

    <%- include('../partials/footer') %>
