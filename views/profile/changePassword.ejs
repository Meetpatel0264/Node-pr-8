<%- include('../partials/header') %>

<div class="content-wrapper">
  <div class="container-xxl flex-grow-1 container-p-y">
    <div class="row justify-content-center gy-6">
      <div class="col-12">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
          <div>
            <h4 class="mb-1">Change Password</h4>
            <p class="mb-0 text-body-secondary">First check your old password, then add new password and confirm it.</p>
          </div>
          <a href="/profile" class="btn btn-outline-secondary">
            <i class="icon-base ri ri-arrow-left-line me-1"></i>
            Back To Profile
          </a>
        </div>
      </div>

      <% if (success) { %>
        <div class="col-lg-8">
          <div class="alert alert-success alert-dismissible" role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="col-lg-8">
          <div class="alert alert-danger alert-dismissible <%= (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) ? "no-auto-hide" : "" %>" data-no-auto-hide="<%= (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) ? "true" : "false" %>" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% } %>

      <div class="col-lg-8">
        <div class="card change-password-card">
          <div class="card-header d-flex align-items-center gap-3">
            <div class="password-icon-box">
              <i class="icon-base ri ri-lock-password-line"></i>
            </div>
            <div>
              <h5 class="mb-0">Update Account Password</h5>
              <small class="text-body-secondary">Logged in user: <%= loginUser ? loginUser.email : '' %></small>
            </div>
          </div>
          <div class="card-body">
            <form action="/change-password" method="POST">
              <% if (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) { %>
                <div class="alert alert-warning change-password-lock-alert no-auto-hide" data-no-auto-hide="true" role="alert">
                  3 incorrect old-password attempts completed. Change Password button is disabled for
                  <strong><span id="changePasswordTimer" data-seconds="<%= remainingSeconds || 1800 %>"><%= remainingSeconds || 1800 %></span></strong>.
                  This timer will stay visible until countdown is complete.
                </div>
              <% } else { %>
                <div class="alert alert-info" role="alert">
                  You have <strong><%= typeof attemptsLeft !== "undefined" ? attemptsLeft : 3 %></strong> attempt(s) for old password. After 3 wrong attempts, change password will lock for 30 minutes.
                </div>
              <% } %>
              <div class="mb-5 form-password-toggle form-control-validation">
                <label class="form-label" for="oldPassword">Old Password</label>
                <div class="input-group input-group-merge">
                  <input type="password" id="oldPassword" name="oldPassword" class="form-control" placeholder="Enter old password" required <%= (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) ? "disabled" : "" %> />
                  <span class="input-group-text cursor-pointer" data-password-toggle="true"><i class="icon-base ri ri-eye-off-line icon-20px"></i></span>
                </div>
                <small class="text-body-secondary">This password is checked from your database account.</small>
              </div>

              <div class="mb-5 form-password-toggle form-control-validation">
                <label class="form-label" for="newPassword">New Password</label>
                <div class="input-group input-group-merge">
                  <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Enter new password" minlength="8" required <%= (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) ? "disabled" : "" %> />
                  <span class="input-group-text cursor-pointer" data-password-toggle="true"><i class="icon-base ri ri-eye-off-line icon-20px"></i></span>
                </div>
                <small class="text-body-secondary">Use minimum 8 characters with uppercase, lowercase, number and special character.</small>
              </div>

              <div class="mb-5 form-password-toggle form-control-validation">
                <label class="form-label" for="confirmPassword">Confirm Password</label>
                <div class="input-group input-group-merge">
                  <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Re-enter new password" minlength="8" required <%= (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) ? "disabled" : "" %> />
                  <span class="input-group-text cursor-pointer" data-password-toggle="true"><i class="icon-base ri ri-eye-off-line icon-20px"></i></span>
                </div>
                <small class="text-body-secondary">Confirm password must match with new password.</small>
              </div>

              <div class="d-flex flex-column flex-sm-row gap-3">
                <button type="submit" class="btn btn-primary" <%= (typeof isChangePasswordBlocked !== "undefined" && isChangePasswordBlocked) ? "disabled data-blocked=\"true\"" : "" %>>
                  <i class="icon-base ri ri-shield-check-line me-1"></i>
                  Change Password
                </button>
                <a href="/profile" class="btn btn-outline-secondary">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .change-password-card {
    overflow: hidden;
  }

  .change-password-card::before {
    content: "";
    display: block;
    height: 6px;
    background: var(--bs-primary);
  }

  .password-icon-box {
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    color: var(--bs-primary);
    background: rgba(102, 108, 255, 0.12);
    font-size: 24px;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const timer = document.getElementById("changePasswordTimer");
    if (!timer) {
      return;
    }

    const formatTime = function (totalSeconds) {
      const minutes = Math.floor(totalSeconds / 60);
      const seconds = totalSeconds % 60;
      return String(minutes).padStart(2, "0") + ":" + String(seconds).padStart(2, "0");
    };

    let secondsLeft = Number(timer.dataset.seconds || timer.textContent) || 1800;
    timer.textContent = formatTime(secondsLeft);

    const interval = setInterval(function () {
      secondsLeft -= 1;
      timer.textContent = formatTime(secondsLeft > 0 ? secondsLeft : 0);

      if (secondsLeft <= 0) {
        clearInterval(interval);
        window.location.href = "/change-password";
      }
    }, 1000);
  });
</script>

<%- include('../partials/footer') %>
